# Server port
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/lost-link

# Auth
JWT_SECRET=your-jwt-secret

# ChatGPT / OpenAI (AIDA chatbot)
# Get a key: https://platform.openai.com/api-keys (sign up; new accounts may get free trial credits)
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: model (default: gpt-4o-mini). Other options: gpt-4o, gpt-3.5-turbo
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Email, Cloudinary, etc.
# EMAIL_USER=
# EMAIL_PASS=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

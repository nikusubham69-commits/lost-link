PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/lost-link
JWT_SECRET=your-jwt-secret

# Twilio SMS (registration OTP on real phone)
# https://www.twilio.com/docs/sms — trial accounts can only SMS "verified" numbers until you upgrade.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email, Cloudinary (optional)
# EMAIL_USER=
# EMAIL_PASS=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
